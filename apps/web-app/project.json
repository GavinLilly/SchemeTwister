{
  "name": "web-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web-app/src",
  "prefix": "schemetwister",
  "tags": [],
  "generators": {
    "@nx/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/web-app",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/web-app/tsconfig.app.json",
        "assets": [
          "apps/web-app/src/favicon.ico",
          "apps/web-app/src/assets",
          "apps/web-app/src/manifest.webmanifest",
          {
            "glob": "*",
            "input": "libs/series/marvel/src/assets/icons/teams",
            "output": "./assets/icons/teams"
          },
          {
            "glob": "*",
            "input": "libs/series/marvel-common/src/assets/icons/teams",
            "output": "./assets/icons/teams"
          },
          {
            "glob": "*",
            "input": "libs/series/marvel-studios/src/assets/icons/teams",
            "output": "./assets/icons/teams"
          },
          {
            "glob": "*",
            "input": "libs/series/marvel-villains/src/assets/icons/teams",
            "output": "./assets/icons/teams"
          }
        ],
        "styles": [
          "apps/web-app/src/styles.scss"
        ],
        "serviceWorker": false
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.ts",
              "with": "apps/web-app/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all",
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ]
        },
        "local": {
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.ts",
              "with": "apps/web-app/src/environments/environment.local.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "continuous": true,
      "options": {
        "proxyConfig": "apps/web-app/proxy.conf.json",
        "buildTarget": "web-app:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "web-app:build:production"
        },
        "local": {
          "buildTarget": "web-app:build:local"
        },
        "development": {
          "buildTarget": "web-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "web-app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/foot-test/jest.config.ts",
        "tsConfig": "apps/foot-test/tsconfig.spec.json"
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "foot-test:build",
        "staticFilePath": "dist/apps/foot-test/browser",
        "spa": true
      }
    },
    "deploy": {
      "executor": "@angular/fire:deploy",
      "options": {}
    }
  }
}
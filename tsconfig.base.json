{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2019", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@schemetwister/home": ["home/src/index.ts"],
      "@schemetwister/libtwister": ["libtwister/src/index.ts"],
      "@schemetwister/randomize": ["randomize/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
